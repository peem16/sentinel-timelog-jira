# TimeLog — OAuth credentials (baked into the build)
#
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง จากนั้น `npm run build` ได้เลย
#   cp .env.example .env      (macOS/Linux)
#   Copy-Item .env.example .env   (Windows PowerShell)
#
# build.rs จะอ่าน .env นี้แล้ว compile ค่าเข้า binary อัตโนมัติ
# (.env อยู่ใน .gitignore แล้ว — จะไม่ถูก commit)
#
# ลงทะเบียน app ครั้งเดียว callback URL = http://127.0.0.1:53817/callback
# ปล่อยว่างไว้ได้ถ้าจะไปกรอกในแอปเองแทน

# --- Atlassian (Jira) ---
# developer.atlassian.com/console/myapps → OAuth 2.0 integration
# Permissions: Jira API → read:jira-work, write:jira-work
TIMELOG_ATLASSIAN_CLIENT_ID=
TIMELOG_ATLASSIAN_CLIENT_SECRET=

# --- Google (Calendar) ---
# console.cloud.google.com → เปิด Google Calendar API
# Credentials → OAuth client ID → type: Desktop app
TIMELOG_GOOGLE_CLIENT_ID=
TIMELOG_GOOGLE_CLIENT_SECRET=

# --- GitHub (PR ที่ review) ---
# github.com/settings/developers → New OAuth App
# Authorization callback URL = http://127.0.0.1:53817/callback
# scope ที่ใช้: repo, read:org, read:user
TIMELOG_GITHUB_CLIENT_ID=
TIMELOG_GITHUB_CLIENT_SECRET=
